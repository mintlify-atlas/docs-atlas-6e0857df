  "keyFeatures": [
    "Digital Product Passport (DPP) creation and management",
    "Product catalog with materials, certifications, and supply chain data",
    "Environmental impact calculation (LCA prediction engine)",
    "Brand customization and theming for public-facing DPPs",
    "Shopify and bulk import/export integrations",
    "EU ESPR compliance tracking and reporting",
    "Multi-tier supply chain traceability",
    "Public REST API and private tRPC API"
  ],
  "publicApiSurface": [
    "Brand management (tRPC: brand.create, brand.update, brand.theme)",
    "Product CRUD (tRPC: products.create, products.update, products.list)",
    "Catalog management (tRPC: catalog.attributes, catalog.materials, catalog.certifications)",
    "Bulk operations (tRPC: bulk.import, bulk.export, bulk.qrExport)",
    "DPP public access (REST: /api/dpp/[brand]/[upid])",
    "Shopify integration (REST: /api/integrations/shopify)",
    "Webhooks (REST: /api/integrations/shopify/webhooks)",
    "Background jobs via Trigger.dev"
  ]
